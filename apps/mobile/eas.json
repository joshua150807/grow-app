{
  "cli": {
    "version": ">= 18.6.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "cache": {
        "disabled": true
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "cache": {
        "disabled": true
      },
      "channel": "preview"
    },
    "beta": {
      "autoIncrement": true,
      "cache": {
        "disabled": true
      },
      "channel": "beta"
    },
    "internal-testflight": {
      "autoIncrement": true,
      "cache": {
        "disabled": true
      },
      "channel": "internal-testflight",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://grow-api-production-4995.up.railway.app",
        "EXPO_PUBLIC_PROFILE_API_V1_ENABLED": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "cache": {
        "disabled": true
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
