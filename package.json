{
  "name": "grow",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm --workspace @grow/mobile run start",
    "android:mobile": "npm --workspace @grow/mobile run android",
    "ios:mobile": "npm --workspace @grow/mobile run ios",
    "web:mobile": "npm --workspace @grow/mobile run web",
    "doctor:mobile": "npm --workspace @grow/mobile run doctor",
    "quality:mobile": "npm --workspace @grow/mobile run quality",
    "dev:api": "npm --workspace @grow/api run dev",
    "build:api": "npm --workspace @grow/api run build",
    "test:api": "npm --workspace @grow/api run test",
    "typecheck:api": "npm --workspace @grow/api run typecheck",
    "typecheck:shared": "npm --workspace @grow/shared run typecheck",
    "build:shared": "npm --workspace @grow/shared run build",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
